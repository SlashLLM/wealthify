# Copy to .env.local for local development with `vercel dev`
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Admin panel (server-only — never expose to the browser)
ADMIN_PASSWORD=your-strong-password
ADMIN_SESSION_SECRET=random-32-char-string
ADMIN_EMAIL=admin@wealthify.co.nz

# Resend (email notifications — server-only)
RESEND_API_KEY=re_xxxxxxxx
RESEND_FROM=Wealthify <hello@wealthify.co.nz>
